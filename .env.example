# -----------------------------------------------------------------------------
# Money Manager Frontend — Environment Configuration Template
# Copy this file to `.env` for local development.
# -----------------------------------------------------------------------------

# Base API URL pointing to the Money Manager Spring Boot backend.
# Local default: http://localhost:8080/api/v1.0
# Production: https://your-backend-app.onrender.com/api/v1.0
VITE_API_BASE_URL=http://localhost:8080/api/v1.0

# Optional: Google OAuth Client ID (if registration/login uses Google OAuth)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
